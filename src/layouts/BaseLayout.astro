---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>TipPal — Gratitude is human. No pressure.</title>
    <meta
      name="description"
      content="TipPal is the easiest way to say thank you with a tip. The first app made exclusively for tipping."
    />

    <!-- Fonts: preconnect + display=swap -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fredoka:wght@600;700&family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />



  </head>
  <body>
    <div style="overflow-x: clip">
      <slot />
    </div>
  </body>
</html>
