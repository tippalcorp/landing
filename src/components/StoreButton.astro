---
export interface Props {
  store: "apple" | "google";
  href: string;
  size?: "md" | "lg";
}

const { store, href, size = "md" } = Astro.props;
const isMd = size === "md";
const padding = isMd ? "10px 20px" : "12px 24px";
const iconSize = isMd ? (store === "apple" ? 22 : 20) : (store === "apple" ? 24 : 21);
const topLabel = isMd ? "10.5px" : "11px";
const bottomLabel = isMd ? "16.5px" : "18px";

const applePath = "M17.05 12.54c-.03-2.9 2.37-4.29 2.48-4.36-1.35-1.97-3.45-2.24-4.2-2.27-1.79-.18-3.49 1.05-4.4 1.05-.9 0-2.3-1.02-3.79-1-1.95.03-3.74 1.13-4.74 2.87-2.02 3.5-.52 8.69 1.45 11.53.96 1.39 2.11 2.95 3.62 2.89 1.45-.06 2-.94 3.76-.94s2.25.94 3.79.91c1.57-.03 2.56-1.42 3.52-2.81 1.11-1.61 1.56-3.17 1.59-3.25-.04-.02-3.05-1.17-3.08-4.62zM14.16 4.1c.8-.97 1.34-2.32 1.19-3.66-1.15.05-2.55.77-3.38 1.74-.74.86-1.39 2.23-1.22 3.55 1.29.1 2.6-.65 3.41-1.63z";
const playPath = "M4 2.5v19l11-9.5L4 2.5zM16.8 10.1l3.3 1.9c1 .6 1 1.4 0 2l-3.3 1.9-2.9-2.9 2.9-2.9z";
---

<a
  href={href}
  class="store-btn"
  style={`padding:${padding}`}
>
  <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d={store === "apple" ? applePath : playPath} />
  </svg>
  <span class="store-btn__labels">
    <span class="store-btn__top" style={`font-size:${topLabel}`}>
      {store === "apple" ? "Download on the" : "Get it on"}
    </span>
    <span class="store-btn__bottom" style={`font-size:${bottomLabel}`}>
      {store === "apple" ? "App Store" : "Google Play"}
    </span>
  </span>
</a>

<style>
  .store-btn {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    background: var(--tippal-accent);
    color: #fff;
    border-radius: 15px;
    box-shadow: var(--tippal-shadow-float);
    transition: transform 150ms var(--tippal-ease-joy);
  }
  .store-btn:hover {
    transform: scale(1.03);
    color: #fff;
  }
  .store-btn__labels {
    text-align: left;
    line-height: 1.15;
  }
  .store-btn__top {
    display: block;
    font-weight: 600;
    opacity: 0.75;
  }
  .store-btn__bottom {
    display: block;
    font-weight: 800;
  }
</style>
