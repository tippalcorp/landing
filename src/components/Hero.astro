---
import HeartIcon from "./HeartIcon.astro";
import StoreButton from "./StoreButton.astro";
---

<section id="top" class="hero">
  <div class="hero__grid">
    <!-- Left column -->
    <div class="hero__left">
      <div class="hero__badge hero-anim" style="animation-delay:0s">
        <HeartIcon size={15} color="var(--tippal-heart)" />
        The first app made exclusively for tipping
      </div>
      <h1 class="hero__title hero-anim" style="animation-delay:.1s">
        Gratitude is human.<br />No pressure.
      </h1>
      <p class="hero__desc hero-anim" style="animation-delay:.2s">
        Tippal is the easiest way to say thank you with a tip.
      </p>
      <div class="hero__stores hero-anim" style="animation-delay:.3s">
        <StoreButton store="apple" href="#get" />
        <StoreButton store="google" href="#get" />
      </div>
      <div class="hero__micro hero-anim" style="animation-delay:.4s">
        Free to download · Tips go to people, not platforms
      </div>
    </div>
    <!-- Right column -->
    <div class="hero__right">
      <div class="hero__card">
        <img
          src="/assets/hug.png"
          alt="Two friends hugging"
          fetchpriority="high"
        />
        <!-- "Tip sent!" pill -->
        <div class="hero__pill">
          <span class="hero__pill-chip">
            <HeartIcon size={15} color="var(--tippal-heart)" />
          </span>
          <span class="hero__pill-text">Tip sent!</span>
          <span class="hero__pill-amount">$5.00</span>
        </div>
        <!-- Floating hearts -->
        <svg class="hero__heart hero__heart--1" width="26" height="26" viewBox="0 0 24 24" fill="var(--tippal-heart)" aria-hidden="true">
          <path d="M12 21s-7.5-4.6-10-9.1C.4 8.6 2.3 5 5.7 5c2 0 3.4 1.1 4.3 2.3l2 2.7 2-2.7C15 6.1 16.3 5 18.3 5c3.4 0 5.3 3.6 3.7 6.9C19.5 16.4 12 21 12 21z" />
        </svg>
        <svg class="hero__heart hero__heart--2" width="19" height="19" viewBox="0 0 24 24" fill="var(--tippal-smile)" aria-hidden="true">
          <path d="M12 21s-7.5-4.6-10-9.1C.4 8.6 2.3 5 5.7 5c2 0 3.4 1.1 4.3 2.3l2 2.7 2-2.7C15 6.1 16.3 5 18.3 5c3.4 0 5.3 3.6 3.7 6.9C19.5 16.4 12 21 12 21z" />
        </svg>
        <svg class="hero__heart hero__heart--3" width="16" height="16" viewBox="0 0 24 24" fill="var(--tippal-calm)" aria-hidden="true">
          <path d="M12 21s-7.5-4.6-10-9.1C.4 8.6 2.3 5 5.7 5c2 0 3.4 1.1 4.3 2.3l2 2.7 2-2.7C15 6.1 16.3 5 18.3 5c3.4 0 5.3 3.6 3.7 6.9C19.5 16.4 12 21 12 21z" />
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    animation: kf-exit linear both;
    animation-timeline: view();
    animation-range: exit 0% exit 75%;
  }
  .hero__grid {
    max-width: 1140px;
    margin: 0 auto;
    padding: 72px 28px 88px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 56px;
    align-items: center;
  }
  .hero__left {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .hero-anim {
    animation: kf-hero-in 0.7s var(--tippal-ease-settle) both;
  }
  .hero__badge {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 8px;
    background: #fff;
    border-radius: 9999px;
    padding: 8px 16px;
    box-shadow: var(--tippal-shadow-rest);
    font-weight: 700;
    font-size: 13.5px;
    color: var(--tippal-accent);
  }
  .hero__title {
    margin: 0;
    font-family: var(--tippal-font-display);
    font-weight: 700;
    font-size: clamp(42px, 5.4vw, 68px);
    line-height: 1.06;
    color: var(--tippal-accent);
  }
  .hero__desc {
    margin: 0;
    max-width: 46ch;
    font-size: 18px;
    line-height: 1.6;
    color: var(--tippal-text-secondary);
    text-wrap: pretty;
  }
  .hero__stores {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 6px;
  }
  .hero__micro {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--tippal-text-tertiary);
  }
  .hero__right {
    position: relative;
    display: flex;
    justify-content: center;
    animation: kf-pop 0.8s var(--tippal-ease-joy) 0.25s both;
  }
  .hero__card {
    position: relative;
    background: #fff;
    border-radius: 24px;
    padding: 28px 34px 60px;
    box-shadow: var(--tippal-shadow-float);
  }
  .hero__card img {
    width: min(300px, 60vw);
    display: block;
  }
  .hero__pill {
    position: absolute;
    left: 50%;
    bottom: -24px;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 9px;
    background: #fff;
    border-radius: 9999px;
    padding: 11px 20px;
    box-shadow: var(--tippal-shadow-float);
    white-space: nowrap;
    animation: tippal-pop var(--tippal-dur-celebrate) var(--tippal-ease-joy) 1.1s both;
  }
  .hero__pill-chip {
    width: 30px;
    height: 30px;
    border-radius: 10px;
    background: var(--tippal-heart-soft);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero__pill-text {
    font-weight: 800;
    font-size: 15.5px;
    color: var(--tippal-accent);
  }
  .hero__pill-amount {
    font-weight: 700;
    font-size: 15.5px;
    color: var(--tippal-heart);
  }

  /* Floating hearts */
  .hero__heart {
    position: absolute;
  }
  .hero__heart--1 {
    top: 18px;
    right: -14px;
    animation: tippal-heart-float 3.2s ease-in 1.4s infinite;
  }
  .hero__heart--2 {
    top: 60px;
    left: -18px;
    animation: tippal-heart-float 3.8s ease-in 2.1s infinite;
  }
  .hero__heart--3 {
    bottom: 90px;
    right: -26px;
    animation: tippal-heart-float 4.4s ease-in 2.8s infinite;
  }
</style>
